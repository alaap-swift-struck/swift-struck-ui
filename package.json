{
  "name": "@swift-struck/ui",
  "version": "0.3.0",
  "description": "Swift Struck UI — a web-first, cross-platform component & collection library you build apps on top of. Inspired by shadcn/ui (primitives) + Glide (data-bound collections). Install straight from GitHub.",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./registry/*": "./registry/*.tsx",
    "./lib/*": "./lib/*.ts",
    "./registry.json": "./registry.json",
    "./styles.css": "./styles.css"
  },
  "files": [
    "styles.css",
    "registry",
    "lib",
    "registry.json",
    "README.md"
  ],
  "workspaces": [
    "www"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=www",
    "build:static": "npm run build:static --workspace=www",
    "start": "npm run start --workspace=www",
    "test": "vitest run",
    "guardrails": "depcruise registry lib --config .dependency-cruiser.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run guardrails && npm run format:check"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "react-leaflet": "^5.0.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "dependency-cruiser": "^16.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
